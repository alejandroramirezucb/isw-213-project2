{
  "all": true,
  "include": [
    "js/psicologo/**/*.js",
    "js/config/**/*.js",
    "js/core/**/*.js"
  ],
  "exclude": [
    "node_modules/**",
    "tests/**",
    "coverage/**"
  ],
  "reporter": [
    "html",
    "text",
    "text-summary",
    "lcov",
    "json"
  ],
  "report-dir": "./coverage",
  "temp-dir": "./.nyc_output",
  "check-coverage": false,
  "per-file": false
}
